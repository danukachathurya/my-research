# API Configuration
# Copy this file to .env and fill in your actual values

# Backend API URL
# For Android emulator: use 10.0.2.2 to access host machine's localhost
# For iOS simulator: use localhost or 127.0.0.1
# For physical device: use your machine's IP address
# For physical Android over USB debugging: use 127.0.0.1 + `adb reverse tcp:8000 tcp:8000`
API_URL=http://10.0.2.2:8000/assess

# RoadResQ backend base URL (garage/towing/spare-parts endpoints)
# Example if RoadResQ backend runs on port 8002:
ROADRESQ_API_URL=http://10.0.2.2:8002

# Car care backend base URL
# Example if the car care backend runs on port 8003:
CAR_CARE_API_URL=http://10.0.2.2:8003

# Gemini API Key (if using Gemini AI for validation)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
